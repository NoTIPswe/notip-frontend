{
  "name": "notip-frontend",
  "version": "1.5.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "vitest",
    "test:watch": "vitest watch",
    "test:cov": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.{ts,html,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css}\"",
    "lint": "eslint \"src/**/*.{ts,html}\" --fix",
    "lint:check": "eslint \"src/**/*.{ts,html}\" --max-warnings=0",
    "lint:report": "eslint \"src/**/*.{ts,html}\" --format json --output-file eslint-report.json",
    "typecheck": "npx tsc --noEmit --project tsconfig.json",
    "fetch:openapi": "bash scripts/generate-openapi.sh"
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/common": "^21.2.6",
    "@angular/compiler": "^21.2.6",
    "@angular/core": "^21.2.6",
    "@angular/forms": "^21.2.6",
    "@angular/platform-browser": "^21.2.6",
    "@angular/platform-browser-dynamic": "^21.2.6",
    "@angular/router": "^21.2.6",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@notip/crypto-sdk": "^1.1.2",
    "keycloak-angular": "^21.0.0",
    "keycloak-js": "^26.2.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.3.1",
    "@angular/build": "^21.2.4",
    "@angular/cli": "^21.2.4",
    "@angular/compiler-cli": "^21.2.6",
    "@eslint/js": "^10.0.1",
    "@openapitools/openapi-generator-cli": "^2.31.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "gitleaks": "^1.0.0",
    "globals": "^17.4.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.0.8",
    "vitest-sonar-reporter": "^3.0.0"
  }
}
